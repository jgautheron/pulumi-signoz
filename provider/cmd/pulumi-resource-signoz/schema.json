    "config": {
        "variables": {
            "accessToken": {
                "type": "string",
                "description": "Access token of the SigNoz API. You can retrieve it from SigNoz UI\nwith Admin Role ([documentation](https://signoz.io/newsroom/launch-week-1-day-5/#using-access-token)).\nAlso, you can set it using environment variable SIGNOZ_ACCESS_TOKEN.",
                "secret": true
            },
            "endpoint": {
                "type": "string",
                "description": "Endpoint of the SigNoz. It is the root URL of the SigNoz UI.\nAlso, you can set it using environment variable SIGNOZ_ENDPOINT. If not set, it defaults to http://localhost:3301."
            },
            "httpMaxRetry": {
                "type": "integer",
                "description": "Specifies the max retry limit for the HTTP requests made to SigNoz.\nAlso, you can set it using environment variable SIGNOZ_HTTP_MAX_RETRY. If not set, it defaults to 10."
            },
            "httpTimeout": {
                "type": "integer",
                "description": "Specifies the timeout limit in seconds for the HTTP requests made to SigNoz.\nAlso, you can set it using environment variable SIGNOZ_HTTP_TIMEOUT. If not set, it defaults to 35."
            }
        }
    },
